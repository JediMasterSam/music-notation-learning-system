{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@mnls/capabilities": ["packages/capabilities/src/index.ts"],
      "@mnls/capability-analysis": ["packages/capability-analysis/src/index.ts"],
      "@mnls/cli": ["packages/cli/src/index.ts"],
      "@mnls/corpus-tools": ["packages/corpus-tools/src/index.ts"],
      "@mnls/harmony": ["packages/harmony/src/index.ts"],
      "@mnls/layout": ["packages/layout/src/index.ts"],
      "@mnls/learning": ["packages/learning/src/index.ts"],
      "@mnls/model": ["packages/model/src/index.ts"],
      "@mnls/normalizer": ["packages/normalizer/src/index.ts"],
      "@mnls/patterns": ["packages/patterns/src/index.ts"],
      "@mnls/pitch": ["packages/pitch/src/index.ts"],
      "@mnls/projection": ["packages/projection/src/index.ts"],
      "@mnls/renderer-html": ["packages/renderer-html/src/index.ts"],
      "@mnls/schema": ["packages/schema/src/index.ts"],
      "@mnls/test-fixtures": ["packages/test-fixtures/src/index.ts"],
      "@mnls/transposition": ["packages/transposition/src/index.ts"],
      "@mnls/validator": ["packages/validator/src/index.ts"],
      "@mnls/workbench": ["packages/workbench/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules", "output"]
}
